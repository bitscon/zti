# Copy this file to ops/deploy.env on barn and fill in your real deploy target.
# Keep ops/deploy.env local-only. Do not commit it.

# Recommended: use an SSH config alias on barn so the repo never stores hostnames,
# usernames, or key paths.
DEPLOY_SSH_TARGET="zti-plesk"
DEPLOY_DOCROOT="/var/www/vhosts/zerotrustintelligence.io/httpdocs"
